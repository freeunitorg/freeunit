[Unit]
Description=%%BRAND_TITLE%% application server (debug)
Wants=network-online.target
After=network-online.target

[Service]
Type=forking
PIDFile=%%RUNDIR%%/%%RUNTIME%%.pid
EnvironmentFile=-/etc/default/%%RUNTIME%%
ExecStart=/usr/sbin/%%RUNTIME%%d-debug $DAEMON_ARGS
ExecReload=

[Install]
WantedBy=multi-user.target
